<%
  const masthead = theme.masthead || {};
  const siteMeta = theme.site || {};

  function pickBg() {
    if (page.cover) return page.cover;
    if (page.top_img) return page.top_img;
    if (page.masthead) return page.masthead;
    if (is_post()) return masthead.post_bg || masthead.default_bg;
    if (page.type === 'about') return masthead.about_bg || masthead.default_bg;
    if (is_archive() || is_category() || is_tag() || page.type === 'categories' || page.type === 'tags') {
      return masthead.archive_bg || masthead.default_bg;
    }
    return masthead.default_bg || '/img/home-bg.svg';
  }

  const bg = pickBg();
  let kind;
  if (is_post()) kind = 'post';
  else if (is_home()) kind = 'site';
  else kind = 'page';

  // heading / subheading / meta
  let heading, subheading, metaLine;
  if (kind === 'post') {
    heading = page.title;
    subheading = page.description || '';
  } else if (kind === 'site' && page.current > 1) {
    heading = config.title;
    subheading = __('pagination.page', page.current);
  } else if (kind === 'site') {
    heading = config.title;
    subheading = siteMeta.subheading || config.subtitle || '';
  } else if (page.type === 'archives' || page.archive) {
    heading = page.title || __('archive.title');
    subheading = page.description || '';
  } else if (page.type === 'categories') {
    heading = page.title || __('categories.title');
    subheading = page.description || '';
  } else if (page.type === 'tags') {
    heading = page.title || __('tags.title');
    subheading = page.description || '';
  } else if (is_category()) {
    heading = page.category || page.title;
    subheading = page.description || '';
  } else if (is_tag()) {
    heading = page.tag || page.title;
    subheading = page.description || '';
  } else {
    heading = page.title || config.title;
    subheading = page.description || page.subtitle || '';
  }
%>
<header class="masthead masthead-<%= kind %>"<% if (bg) { %> style="background-image: url('<%- url_for(bg) %>')"<% } %>>
  <div class="masthead-overlay" aria-hidden="true"></div>
  <div class="masthead-container">
    <div class="masthead-inner">
      <% if (kind === 'post') { %>
        <div class="post-heading">
          <h1><%= heading %></h1>
          <% if (subheading) { %><h2 class="subheading"><%= subheading %></h2><% } %>
          <span class="meta">
            <%= __('post.posted_by') %>
            <a href="<%- url_for('/about/') %>"><%= page.author || config.author %></a>
            <%= __('post.posted_on') %>
            <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, config.date_format) %></time>
          </span>
        </div>
      <% } else if (kind === 'site') { %>
        <div class="site-heading">
          <h1><%= heading %></h1>
          <% if (subheading) { %><span class="subheading"><%= subheading %></span><% } %>
        </div>
      <% } else { %>
        <div class="page-heading">
          <h1><%= heading %></h1>
          <% if (subheading) { %><span class="subheading"><%= subheading %></span><% } %>
        </div>
      <% } %>
    </div>
  </div>
</header>
