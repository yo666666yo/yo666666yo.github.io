<%
  const menu = theme.menu || {};
  const menuEntries = Object.keys(menu).filter(function (label) {
    const href = String(menu[label] || '').replace(/\/+$/, '/') || '/';
    return label !== '分类' && href !== '/categories/';
  });
  const searchPath = (config.search && config.search.path) || 'search.xml';
  const searchUrl = url_for('/' + searchPath.replace(/^\/+/, ''));
  const searchPageUrl = url_for('/search/');
%>
<nav id="mainNav" class="navbar navbar-light" aria-label="<%= __('nav.menu_aria') %>">
  <div class="navbar-container">
    <a class="navbar-brand" href="<%- url_for('/') %>"><%= config.title %></a>
    <button class="navbar-toggler" type="button" aria-controls="navbarResponsive" aria-expanded="false" aria-label="<%= __('nav.toggle') %>">
      <%= __('nav.toggle') %>
      <span class="navbar-toggler-icon" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
    <div class="navbar-collapse" id="navbarResponsive">
      <form class="site-search" role="search" action="<%- searchPageUrl %>" method="get" data-search-url="<%- searchUrl %>" data-search-page-url="<%- searchPageUrl %>" data-loading="正在搜索..." data-no-results="没有找到匹配文章" data-error="搜索索引暂时不可用">
        <label class="sr-only" for="site-search-input">搜索文章</label>
        <input id="site-search-input" class="site-search-input" type="search" name="q" placeholder="搜索文章..." autocomplete="off" spellcheck="false" aria-controls="site-search-results" aria-expanded="false" />
        <button class="site-search-button" type="submit" aria-label="搜索">
          <svg class="site-search-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10.8 5.2a5.6 5.6 0 1 0 0 11.2 5.6 5.6 0 0 0 0-11.2Zm-7.1 5.6a7.1 7.1 0 1 1 12.6 4.5l3.7 3.7-1.1 1.1-3.7-3.7A7.1 7.1 0 0 1 3.7 10.8Z" />
          </svg>
        </button>
        <div id="site-search-results" class="site-search-results" role="listbox" hidden></div>
      </form>
      <ul class="navbar-nav">
        <% menuEntries.forEach(function (label) { %>
          <% const href = menu[label]; %>
          <% const active = (page.path && href !== '/' && ('/' + page.path).startsWith(href)) || (href === '/' && is_home() && page.current === 1); %>
          <li class="nav-item">
            <a class="nav-link<%= active ? ' active' : '' %>" href="<%- url_for(href) %>"><%= label %></a>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
</nav>
