<div class="container home-container">
  <div class="home-layout">
    <section class="home-posts" aria-label="Recent posts">
      <% if (page.posts && page.posts.length) { %>
        <% page.posts.each(function (post) { %>
          <%- partial('_partial/post-preview', { post: post }) %>
        <% }); %>
        <%- partial('_partial/pagination') %>
      <% } else { %>
        <p class="empty-state"><%= __('index.empty') %></p>
      <% } %>
    </section>

    <aside class="home-tags" aria-labelledby="home-tags-title">
      <div class="home-tags-card">
        <h2 id="home-tags-title" class="home-tags-title">标签云图</h2>
        <%- partial('_partial/tag-cloud', { variant: 'home-svg' }) %>
      </div>
    </aside>
  </div>
</div>
