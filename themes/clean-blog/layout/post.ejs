<article class="article article-post mb-4">
  <div class="container article-container">
    <div class="article-layout" data-article-layout>
      <aside class="article-toc-sidebar" data-toc-sidebar hidden>
        <nav class="article-toc" aria-label="Table of contents">
          <div class="article-toc-header">
            <span class="article-toc-title">Contents</span>
            <button class="article-toc-collapse" type="button" data-toc-collapse aria-label="Collapse table of contents" aria-expanded="true">
              <span aria-hidden="true"></span>
            </button>
          </div>
          <div class="article-toc-scroll" data-toc-scroll>
            <ol class="article-toc-list" data-toc-list></ol>
          </div>
        </nav>
      </aside>

      <div class="article-content-col">
        <div class="post-body"><%- page.content %></div>

        <% if (page.tags && page.tags.length) { %>
        <div class="post-tags">
          <span class="post-tags-label"><%= __('post.tags') %>:</span>
          <% page.tags.each(function (t) { %>
            <a class="post-tag" href="<%- url_for(t.path) %>">#<%= t.name %></a>
          <% }); %>
        </div>
        <% } %>

        <nav class="post-pager" aria-label="post navigation">
          <% if (page.prev) { %>
            <a class="post-pager-item post-pager-prev" href="<%- url_for(page.prev.path) %>">
              <span class="post-pager-label"><%= __('post.prev') %></span>
              <span class="post-pager-title"><%= page.prev.title %></span>
            </a>
          <% } else { %>
            <span></span>
          <% } %>
          <% if (page.next) { %>
            <a class="post-pager-item post-pager-next" href="<%- url_for(page.next.path) %>">
              <span class="post-pager-label"><%= __('post.next') %></span>
              <span class="post-pager-title"><%= page.next.title %></span>
            </a>
          <% } %>
        </nav>

        <%- partial('_partial/comments') %>
      </div>
    </div>
  </div>

  <button class="toc-fab" type="button" data-toc-open aria-label="Open table of contents" aria-controls="article-toc-drawer" hidden>
    <span class="toc-fab-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <div class="toc-drawer" id="article-toc-drawer" data-toc-drawer aria-hidden="true" hidden>
    <div class="toc-drawer-backdrop" data-toc-close></div>
    <section class="toc-drawer-panel" role="dialog" aria-modal="true" aria-labelledby="toc-drawer-title" tabindex="-1">
      <div class="toc-drawer-header">
        <h2 id="toc-drawer-title">Contents</h2>
        <button class="toc-drawer-close" type="button" data-toc-close aria-label="Close table of contents">
          <span aria-hidden="true"></span>
        </button>
      </div>
      <div class="toc-drawer-scroll">
        <ol class="article-toc-list toc-drawer-list" data-toc-mobile-list></ol>
      </div>
    </section>
  </div>
</article>
